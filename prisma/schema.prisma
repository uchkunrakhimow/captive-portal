generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Post {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  phoneNum   String   @db.VarChar(255)
  clientIp   String?
  otp        String?
  macAddress String?
  ap         String?
  ssid       String?
}
