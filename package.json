{
  "name": "radius-node",
  "version": "1.0.2",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "server:dev": "npx nodemon src/server.ts",
    "dev": "concurrently \"npm run dev:client\" \"npm run server:dev\"",
    "dev:build": "tsc",
    "build": "rm -rf dist && npm run dev:build && cd client && rm -rf dist && npm run build",
    "server:start": "node dist/server.js",
    "server:format": "prettier --write ."
  },
  "author": "Uchkun Rakhimov <uchkunrakhimov@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-winston": "^4.2.0",
    "multer": "1.4.5-lts.1",
    "node-unifi": "^2.5.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.1.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "prisma": "^5.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
